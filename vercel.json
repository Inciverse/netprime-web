{
  "rewrites": [
    { "source": "/sbs/:match*", "destination": "https://vidsrc.sbs/:match*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
